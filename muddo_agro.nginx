# /etc/nginx/sites-available/muddo_agro
# Replace "yourdomain.com" with your actual domain

server {
    listen 80;
    server_name yourdomain.com www.yourdomain.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name yourdomain.com www.yourdomain.com;

    # SSL — managed by certbot
    ssl_certificate     /etc/letsencrypt/live/yourdomain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/yourdomain.com/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # Static files served directly by Nginx (fast, no Python overhead)
    location /static/ {
        alias /home/muddo/muddo_agro/static/;
        expires 30d;
        add_header Cache-Control "public, immutable";
        gzip_static on;
    }

    # Uploaded product images
    location /uploads/ {
        alias /home/muddo/muddo_agro/static/uploads/;
        expires 7d;
        add_header Cache-Control "public";
    }

    # Service worker — no cache so updates propagate immediately
    location /static/sw.js {
        alias /home/muddo/muddo_agro/static/sw.js;
        add_header Cache-Control "no-cache";
    }

    # Everything else → Gunicorn
    location / {
        proxy_pass         http://127.0.0.1:5000;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
        client_max_body_size 10M;  # for product image uploads
    }

    # Logs
    access_log /var/log/nginx/muddo_agro_access.log;
    error_log  /var/log/nginx/muddo_agro_error.log;
}
